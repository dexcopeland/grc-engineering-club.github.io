<article
  class="card"
  style="--i:{{ loop.index0 }}"
  data-specializations="{{ (engineer.data.specializations or []) | join(',') | lower }}"
  data-frameworks="{{ (engineer.data.frameworks or []) | join(',') | lower }}"
  data-available="{{ (engineer.data.available_for or []) | join(',') | lower }}"
  data-languages="{{ (engineer.data.languages or []) | join(',') | lower }}"
  data-name="{{ engineer.data.name | lower }}"
>
  <div class="card-header">
    <img
      src="https://github.com/{{ engineer.data.github }}.png?size=200"
      alt="{{ engineer.data.name }}"
      class="card-avatar"
      width="64"
      height="64"
      loading="lazy"
    >
    <div>
      <a href="/engineers/{{ engineer.data.github }}/" class="card-name">{{ engineer.data.name }}</a>
      {% if engineer.data.title %}<p class="card-title">{{ engineer.data.title }}</p>{% endif %}
      {% if engineer.data.company %}<p class="card-company">{{ engineer.data.company }}</p>{% endif %}
    </div>
  </div>

  {% if engineer.data.location %}
  <p class="card-location">{{ engineer.data.location }}</p>
  {% endif %}

  {% if engineer.data.specializations and engineer.data.specializations.length %}
  <div class="card-tags">
    {% for s in engineer.data.specializations %}<span class="tag tag-accent">{{ s }}</span>{% endfor %}
  </div>
  {% endif %}

  {% if engineer.data.frameworks and engineer.data.frameworks.length %}
  <div class="card-tags">
    {% for f in engineer.data.frameworks %}{% if loop.index0 < 4 %}<span class="tag tag-outline">{{ f }}</span>{% endif %}{% endfor %}
    {% if engineer.data.frameworks.length > 4 %}<span class="tag tag-outline">+{{ engineer.data.frameworks.length - 4 }} more</span>{% endif %}
  </div>
  {% endif %}

  {% if engineer.data.languages and engineer.data.languages.length %}
  <div class="card-tags">
    {% for l in engineer.data.languages %}{% if loop.index0 < 4 %}<span class="tag tag-language">{{ l }}</span>{% endif %}{% endfor %}
    {% if engineer.data.languages.length > 4 %}<span class="tag tag-language">+{{ engineer.data.languages.length - 4 }} more</span>{% endif %}
  </div>
  {% endif %}

  {% if engineer.data.available_for and engineer.data.available_for.length %}
  <div class="card-available">
    {% for a in engineer.data.available_for %}<span class="badge-available">{{ a }}</span>{% endfor %}
  </div>
  {% endif %}

  <div class="card-links">
    <a href="https://github.com/{{ engineer.data.github }}" target="_blank" rel="noopener" title="GitHub">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    {% if engineer.data.linkedin %}
    <a href="{{ engineer.data.linkedin }}" target="_blank" rel="noopener" title="LinkedIn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    {% endif %}
    {% if engineer.data.blog %}
    <a href="{{ engineer.data.blog }}" target="_blank" rel="noopener" title="Blog">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
    </a>
    {% endif %}
    {% if engineer.data.website %}
    <a href="{{ engineer.data.website }}" target="_blank" rel="noopener" title="Website">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
    </a>
    {% endif %}
    {% if engineer.data.portfolio %}
    <a href="{{ engineer.data.portfolio }}" target="_blank" rel="noopener" title="Portfolio">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
    </a>
    {% endif %}
  </div>
</article>
